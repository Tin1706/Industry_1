window['wistiajsonp-/embed/medias/y00gler2sk.jsonp'] = {"media":{"accountId":70595,"accountHashedId":"0wochyyxjn","accountKey":"wistia-production_70595","analyticsHost":"https://distillery.wistia.net","formsHost":"https://app.wistia.com","formEventsApi":"/form-stream/1.0.0","aspectRatio":1.7777777777777777,"assets":[{"is_enhanced":false,"type":"original","slug":"original","display_name":"Original File","details":{},"width":1920,"height":1080,"size":345332653,"bitrate":10075,"public":true,"status":2,"progress":1.0,"url":"https://embed-ssl.wistia.com/deliveries/b6677658d4a313c10de577567729387c.bin","created_at":1559755944},{"is_enhanced":false,"type":"iphone_video","slug":"mp4_h264_582k","display_name":"360p","details":{},"container":"mp4","codec":"h264","width":640,"height":360,"ext":"mp4","size":19971809,"bitrate":582,"public":true,"status":2,"progress":1.0,"metadata":{"max_bitrate":153943,"average_bitrate":79588,"early_max_bitrate":198126},"url":"https://embed-ssl.wistia.com/deliveries/f2e49d542323fdaa32fe348fb62c5048f69d1095.bin","created_at":1559755944,"segment_duration":3,"opt_vbitrate":1200},{"is_enhanced":false,"type":"mp4_video","slug":"mp4_h264_267k","display_name":"224p","details":{},"container":"mp4","codec":"h264","width":400,"height":224,"ext":"mp4","size":9155215,"bitrate":267,"public":true,"status":2,"progress":1.0,"metadata":{"max_bitrate":13285,"average_bitrate":11698,"early_max_bitrate":14852},"url":"https://embed-ssl.wistia.com/deliveries/05135ff3ced16bccb5eca2244e66fd2ec58e322c.bin","created_at":1559755944,"segment_duration":3,"opt_vbitrate":300},{"is_enhanced":false,"type":"md_mp4_video","slug":"mp4_h264_729k","display_name":"540p","details":{},"container":"mp4","codec":"h264","width":960,"height":540,"ext":"mp4","size":25003817,"bitrate":729,"public":true,"status":2,"progress":1.0,"metadata":{"max_bitrate":195777,"average_bitrate":98675,"early_max_bitrate":222820},"url":"https://embed-ssl.wistia.com/deliveries/99b55c1b1e07723dcc200c4b55b3eb177e472217.bin","created_at":1559755944,"segment_duration":3,"opt_vbitrate":1800},{"is_enhanced":false,"type":"hd_mp4_video","slug":"mp4_h264_1080k","display_name":"720p","details":{},"container":"mp4","codec":"h264","width":1280,"height":720,"ext":"mp4","size":37022770,"bitrate":1080,"public":true,"status":2,"progress":1.0,"metadata":{"max_bitrate":276780,"average_bitrate":144584,"early_max_bitrate":368955},"url":"https://embed-ssl.wistia.com/deliveries/9b88ed93d2f96191a5a843d1074adb46649512f5.bin","created_at":1559755944,"segment_duration":3,"opt_vbitrate":3750},{"is_enhanced":false,"type":"hd_mp4_video","slug":"mp4_h264_2287k","display_name":"1080p","details":{},"container":"mp4","codec":"h264","width":1920,"height":1080,"ext":"mp4","size":78375278,"bitrate":2287,"public":true,"status":2,"progress":1.0,"metadata":{"max_bitrate":496426,"average_bitrate":302342,"early_max_bitrate":614565},"url":"https://embed-ssl.wistia.com/deliveries/24a9e166eee10feb2042a8cd92dbd0198496bfd1.bin","created_at":1559755944,"segment_duration":3,"opt_vbitrate":5625},{"is_enhanced":false,"type":"storyboard","slug":"storyboard_2000x2260","display_name":"Storyboard","details":{},"width":2000,"height":2260,"ext":"jpg","size":832570,"bitrate":0,"public":true,"status":2,"progress":1.0,"metadata":{"frame_width":200,"frame_height":113,"frame_count":200,"aspect_ratio":1.7777777777777777},"url":"https://embed-ssl.wistia.com/deliveries/f5db87f9d4cb0843b6866f80df70c5608f1e8e77.bin","created_at":1559755944},{"is_enhanced":false,"type":"still_image","slug":"still_image_1920x1080","display_name":"Thumbnail Image","details":{},"width":1920,"height":1080,"ext":"jpg","size":113003,"bitrate":0,"public":true,"status":2,"progress":1.0,"url":"https://embed-ssl.wistia.com/deliveries/93ac210754454fe327d20fec8c37a5658f89f15c.bin","created_at":1559755944}],"branding":false,"createdAt":1533237509,"distilleryUrl":"https://distillery.wistia.com/x","duration":267.727,"enableCustomerLogo":true,"firstEmbedForAccount":false,"firstShareForAccount":false,"availableTranscripts":[{"bcp47LanguageTag":"en","familyName":"English","familyNativeName":"English","hasCaptions":true,"hasVideoStream":false,"name":"English","nativeName":"English","wistiaLanguageCode":"eng","language":"eng","ietf_language_tag":"eng","alpha3_terminologic":"eng","alpha3_bibliographic":"eng","iso639_2_language_code":"en","english_name":"English","native_name":"English","right_to_left":false,"alpha3Bibliographic":"eng","alpha3Terminologic":"eng","ietfLanguageTag":"eng","iso6392LanguageCode":"en","genericName":"English","genericNativeName":"English"},{"bcp47LanguageTag":"ja","familyName":"Japanese","familyNativeName":"日本語","hasCaptions":true,"hasVideoStream":false,"name":"Japanese","nativeName":"日本語","wistiaLanguageCode":"jpn","language":"jpn","ietf_language_tag":"jpn","alpha3_terminologic":"jpn","alpha3_bibliographic":"jpn","iso639_2_language_code":"ja","english_name":"Japanese","native_name":"日本語","right_to_left":false,"alpha3Bibliographic":"jpn","alpha3Terminologic":"jpn","ietfLanguageTag":"jpn","iso6392LanguageCode":"ja","genericName":"Japanese","genericNativeName":"日本語"}],"hashedId":"y00gler2sk","mediaId":35625020,"mediaKey":"wistia-production_35625020","mediaType":"Video","name":"Chobani","preloadPreference":null,"progress":1.0,"protected":false,"projectId":3395645,"seoDescription":"a Case Studies - 2018 video","showAbout":true,"status":2,"type":"Video","playableWithoutInstantHls":true,"privacyMode":true,"stats":{"loadCount":677958,"playCount":6863,"uniqueLoadCount":468727,"uniquePlayCount":6347,"averageEngagement":0.553554},"trackingTransmitInterval":20,"liveStreamEventDetails":null,"integrations":{"google_analytics":true},"captions":[{"language":"eng","text":"(optimistic music) -I'm Hugh Rodney, Vice President of Global Engineering and Project Management here at Chobani. We have three facilities world wide. One in New York, one in Australia, and one in here, in Twin Falls, Idaho. Twin Falls, Idaho's the largest yogurt manufacturing facility in the world.\n\nIt's built on a 200 acre site. Ignition has really taken Chobani by storm. We have many, many different platforms, from an HMI controls automation perspective, but once we brought Ignition on board, it opened up a new world for us in terms of what we could do with such a simple, simplistic piece of software, and we've taken that from the shop plant floor level, all the way to top to our enterprise executive level. (optimistic music) We believe that Ignition has endless opportunities for us here at Chobani.\n\nIt gives us the opportunity to integrate not only the plant floor, but also our quality systems. Our asset management systems, we have integrated to our ERP systems, and we use it for all our CapEx project management across the board. At one, it's given us one whole integration system from the OT, and allowing us to integrate the OT environment, and the IT environment into one. (optimistic music) We've integrated our Ignition on each one of the filler lines, packaging lines.\n\nIgnition has really given us the ability to improve the efficiency on our lines, and also reduce the amount of downtime that we've had. Once we took Ignition on board as one of our enterprise platforms, everything has improved exponentially across the board from an operations standpoint. -I'm J.C Givens, Global Network Services Manager for Chobani.\n\nIgnition really made it simplified, the ability to get the information to the plant floor. It was a fast, clean install that was able to get that information to our operators in a timely manner.\n\n- My name is Trevor Bell. I'm an Automation Engineer here at Chobani Twin Falls. One of the nice things about Ignition has been, we have a new client that we need to install, or a new dashboard that somebody at the plant wants to use, it's really great for some one off items that would have traditionally gone to our old HMI application, but it's a faster rollout with Ignition, and then obviously we don't have to deal with any of the client licensing issues that we had with other applications.\n\n- I'm John Furby. I'm an Automation Engineer for Chobani. So any time we have a need for new HMI interface, we can roll out an Ignition client anywhere we want to any operating system, or even phones or iPads, so we can use them in the plant anywhere at any time. (optimistic music) - We saw a massive improvement in the amount of downtime once we utilized the power of Ignition, to really give us better visualization of what was actually happening on the line from a day to day basis, and from an hour to hour perspective.\n\n- One if the nice things about Ignition is the Python development in the background. With that scripting capabilities, you can really get any kind of customization you want.\n\n- We're trying to support this really large plant, really complex plant. Anything we can do to decrease our development time is pretty valuable.\n\n- Custom templates have been really nice. Being able to customize them, and change them on the fly is great.\n\n- Ignition has proven itself throughout all of our facilities. (optimistic music) - Ignition has many unique features about it, and the fact that we can actually put Ignition down on the low level, at the plant floor, and actually take it all the way to the top for high level executive dashboards, really brings the power to us with something that's very inexpensive and very easy to implement.\n\n- Ignition gives us the ability to get information to the operators real time so that they can make real time decisions.\n\n- We believe that providing as much data as possible to the plant floor, and not only to the executive level, really gives us benefit and value for money, and really helps us become more efficient on a daily basis. (optimistic music)"}],"hls_enabled":true,"embed_options":{"opaqueControls":false,"playerColor":"545767","playerColorGradient":{"on":false,"colors":[["#54bbff",0],["#baffff",1]]},"plugin":{"postRoll-v1":{"rewatch":"true","text":"","link":"https://inductiveautomation.com/resources/casestudy","time":"end","autoSize":"true","style":{"backgroundColor":"#303030"},"ctaType":"image","image":"https://embed-ssl.wistia.com/deliveries/d35429ee3162f9215a622ce651f51fc5.png","on":"true","conversionOpportunityKey":"wistia-production_3641801"},"captions-v1":{"language":"","onByDefault":"false","on":"true","async":"false"},"share":{"channels":"email-facebook-linkedIn","pageTitle":"Chobani","pageUrl":"https%3A%2F%2Finductiveautomation.com%2Fresources%2Fcasestudy%2Fworlds-largest-yogurt-plant-thrives-on-ignition","tweetText":"{video_name}","overrideUrl":"true","on":"true","conversionOpportunityKey":"wistia-production_3518019"}},"volumeControl":"true","fullscreenButton":"true","controlsVisibleOnLoad":"true","bpbTime":"false","anonymizeIp":true,"vulcan":true,"branding":"false","showCustomerLogo":"true","autoPlay":"false","endVideoBehavior":"default","playButton":"true","smallPlayButton":"true","playbar":"true","settingsControl":"true","playbackRateControl":"true","qualityControl":"true","spherical":"false","newRoundedIcons":true,"shouldShowCaptionsSettings":true},"embedOptions":{"opaqueControls":false,"playerColor":"545767","playerColorGradient":{"on":false,"colors":[["#54bbff",0],["#baffff",1]]},"plugin":{"postRoll-v1":{"rewatch":"true","text":"","link":"https://inductiveautomation.com/resources/casestudy","time":"end","autoSize":"true","style":{"backgroundColor":"#303030"},"ctaType":"image","image":"https://embed-ssl.wistia.com/deliveries/d35429ee3162f9215a622ce651f51fc5.png","on":"true","conversionOpportunityKey":"wistia-production_3641801"},"captions-v1":{"language":"","onByDefault":"false","on":"true","async":"false"},"share":{"channels":"email-facebook-linkedIn","pageTitle":"Chobani","pageUrl":"https%3A%2F%2Finductiveautomation.com%2Fresources%2Fcasestudy%2Fworlds-largest-yogurt-plant-thrives-on-ignition","tweetText":"{video_name}","overrideUrl":"true","on":"true","conversionOpportunityKey":"wistia-production_3518019"}},"volumeControl":"true","fullscreenButton":"true","controlsVisibleOnLoad":"true","bpbTime":"false","anonymizeIp":true,"vulcan":true,"branding":"false","showCustomerLogo":"true","autoPlay":"false","endVideoBehavior":"default","playButton":"true","smallPlayButton":"true","playbar":"true","settingsControl":"true","playbackRateControl":"true","qualityControl":"true","spherical":"false","newRoundedIcons":true,"shouldShowCaptionsSettings":true}},"options":{}};
